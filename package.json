{
  "name": "cabinetavocats",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "npm run api:dev",
    "dev:full": "concurrently -k -n api,web -c blue,green \"npm:api:dev\" \"npm:dev\"",
    "dev:ci": "concurrently -k -n api,web -c blue,green \"npm:api:start\" \"npm:dev\"",
    "api:dev": "node --watch server/index.js",
    "api:start": "node server/index.js",
    "db:seed": "npm run db:seed:quick",
    "db:seed:minimal": "node scripts/run-sql-file.mjs peuplement_minimal.sql",
    "db:seed:quick": "node scripts/run-sql-file.mjs peuplement_rapide.sql",
    "db:seed:massive": "node scripts/run-sql-file.mjs peuplement_massif.sql",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "concurrently": "^9.2.1",
    "cypress": "^15.12.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vue-tsc": "^3.2.5",
    "wait-on": "^9.0.4"
  }
}
